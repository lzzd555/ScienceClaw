# ── 基础服务 ──
MONGODB_HOST=localhost
MONGODB_PORT=27014
MONGODB_USER=
MONGODB_PASSWORD=
WEBSEARCH_BASE_URL=http://localhost:8068

# ── 运行模式 ──
# STORAGE_BACKEND=local  -> 本地模式，RUNTIME_MODE 和大部分 SANDBOX_* 配置不参与主流程
# STORAGE_BACKEND!=local -> 沙箱模式，RUNTIME_MODE 生效
STORAGE_BACKEND=local
LOCAL_PATH_STYLE=windows

# 仅在沙箱模式下生效：
#   shared      -> 所有 session 共用一个 sandbox
#   docker      -> 每个 session 启一个独立 Docker sandbox
#   session_pod -> 每个 session 启一个独立 Kubernetes Pod
RUNTIME_MODE=shared

# ── 沙箱主参数 ──
# 沙箱模式下推荐只配置这个主参数。
# 未显式设置下列细项时，系统会从 SANDBOX_BASE_URL 自动派生：
#   SANDBOX_MCP_URL         = SANDBOX_BASE_URL + /mcp
#   SANDBOX_VNC_WS_URL      = from SANDBOX_BASE_URL
SANDBOX_BASE_URL=http://localhost:18080

# ── 沙箱可选覆盖项 ──
# 仅在需要覆盖默认派生值时设置；大多数部署可以留空/删除。
# SANDBOX_MCP_URL=http://localhost:18080/mcp
# SANDBOX_VNC_WS_URL=ws://localhost:18080/vnc/websockify

# ── 统一根目录 ──
# 设置 RPA_CLAW_HOME 后，以下子目录自动派生：
#   workspace        → RPA_CLAW_HOME/workspace
#   external_skills  → RPA_CLAW_HOME/external_skills
#   builtin_skills   → RPA_CLAW_HOME/builtin_skills
#   data             → RPA_CLAW_HOME/data
# 也可单独设置覆盖：WORKSPACE_DIR / EXTERNAL_SKILLS_DIR / BUILTIN_SKILLS_DIR / LOCAL_DATA_DIR
RPA_CLAW_HOME=

# Docker 沙箱内的根目录（默认 /home/rpaclaw，一般无需修改）
# SANDBOX_RPA_CLAW_HOME=/home/rpaclaw
